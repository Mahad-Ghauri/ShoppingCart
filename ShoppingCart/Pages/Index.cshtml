@page
@model IndexModel
@{
    ViewData["Title"] = "Shop";
}

<div class="shop-container">
    <h1>Our Products</h1>
    <div class="product-grid">
        @foreach (var Product in Model.Products)
        {
            <div class="product-card">
                <img src="~/Images/@Product.Image" class="product-image" alt="@Product.Name" />
                <h3>@Product.Name</h3>
                <p class="price">$@Product.Price</p>
                <a class="btn btn-primary" asp-page="Cart" asp-route-id="@Product.Id">Add to Cart</a>
            </div>
        }
    </div>
    <a href="/Cart" class="view-cart-btn">View Cart</a>
</div>

<style>
    /* Container for product listing */
    .shop-container {
        max-width: 1500px;
        margin: 0 auto;
        padding: 20px;
    }

    /* Title styling */
    .shop-container h1 {
        text-align: center;
        font-size: 2.5rem;
        margin-bottom: 40px;
        color: #333;
    }

    /* Grid layout for product cards */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
    }

    /* Product card styling */
    .product-card {
        background-color: #FFEEEE;
        padding: 20px;
        border: none;
        border-radius: 20px;
        text-align: center;
        justify-content: center;
        align-items: center;
        transition-duration: 0.5s;
    }

    /* Hover effect for product cards */
    .product-card:hover {
        transform: scale(1.08);
        border-radius: 2rem;
        border: none;
        box-shadow: -3px -3px 1rem rgb(0, 0, 0, 0.8);
    }

    /* Product image */
    .product-image {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    /* Product name */
    .product-card h3 {
        font-size: 1.25rem;
        margin: 10px 0;
        color: #333;
    }

    /* Price */
    .price {
        font-size: 1.1rem;
        color: #ff5722;
        margin-bottom: 15px;
    }

    /* Button styling */
    .btn-primary {
        background-color: #ff5722;
        border: none;
        padding: 10px 20px;
        color: #fff;
        text-transform: uppercase;
        cursor: pointer;
        border-radius: 5px;
        font-size: 1rem;
    }

    /* Button hover */
    .btn-primary:hover {
        background-color: #e64a19;
    }

    .view-cart-btn {
        position: fixed;
        right: 20px;
        bottom: 77px;
        background-color: #FFEDBC;
        color: chocolate;
        padding: 10px 20px;
        border-radius: 40px;
        text-transform: uppercase;
        text-decoration:none;
        text-align: center;
        font-size: 1.2rem;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        transition-duration:0.8s;
    }

    .view-cart-btn:hover {
        background-color: #ED4264;
        transform: scale(1.1);
        color:aliceblue;
        text-decoration:none;
    }
</style>
