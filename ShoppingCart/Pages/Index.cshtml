@page
@model IndexModel
@{
    ViewData["Title"] = "Shop";
}

<div class="shop-container">
    <h1>Our Products</h1>
    <div class="product-grid">
        @foreach (var Product in Model.Products)
        {
            <div class="product-card">
                <img src="~/Images/@Product.Image" class="product-image" alt="@Product.Name" />
                <h3>@Product.Name</h3>
                <p class="price">$@Product.Price</p>
                <a class="btn btn-primary" asp-page="Cart" asp-route-id="@Product.Id">Add to Cart</a>
            </div>
        }
    </div>
    <a href="/Cart" class="view-cart-btn">View Cart</a>
</div>

<style>
    /* Container for product listing */
    .shop-container {
        max-width: 1500px;
        margin: 0 auto;
        padding: 20px;
        background: linear-gradient(135deg, #8e44ad 0%, #b84b54 50%, #e74c3c 100%); 
        border-radius: 20px; 
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2); 
    }

        /* Title styling */
     .shop-container h1 {
        text-align: center;
        font-size: 2.5rem;
        margin-bottom: 40px;
        color: #fff; 
     }

    /* Grid layout for product cards */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
    }

    /* Product card styling */

    .product-card {
        background-color: rgba(250, 128, 114, 0.9);
        padding: 20px;
        border: none;
        border-radius: 20px;
        text-align: center;
        justify-content: center;
        align-items: center;
        transition-duration: 0.5s;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1); 
    }

        /* Hover effect for product cards */
    .product-card:hover {
        transform: scale(1.08);
        border-radius: 2rem;
        border: none;
        box-shadow: -3px -3px 1rem rgba(0, 0, 0, 0.8);
    }

    /* Product image */
    .product-image {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin-bottom: 15px;
    }

    /* Product name */
    .product-card h3 {
        font-size: 1.25rem;
        margin: 10px 0;
        color: #333; 
    }

    /* Price */
    .price {
        font-size: 1.1rem;
        color:antiquewhite; 
        margin-bottom: 15px;
    }

    /* Button styling */
    .btn-primary {
        background-color: #FFC3A0; 
        color: chocolate; 
        border: none;
        padding: 10px 20px;
        text-transform: uppercase;
        cursor: pointer;
        border-radius: 10px;
        font-size: 1rem;
        transition: background-color 0.3s;
        transition-duration:0.6s;
    }

        /* Button hover */
    .btn-primary:hover {
        transform: scale(1.05);
        background-color: #FF7F50;
        color: #fff; 
    }

    .view-cart-btn {
        position: fixed;
        right: 20px;
        bottom: 77px;
        background-color: #FFC3A0; 
        color: #5D5C61; 
        padding: 10px 20px;
        border-radius: 40px;
        text-transform: uppercase;
        text-decoration: none;
        text-align: center;
        font-size: 1.2rem;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        cursor: pointer;
        transition-duration: 0.8s;
    }

    .view-cart-btn:hover {
        background-color: #FF6F61; 
        transform: scale(1.1);
        color: #fff; 
        text-decoration: none;
    }
</style>
    